{% extends 'base.html.twig' %}

{% block stylesheets %}
    {{ parent() }}

{% endblock %}

{% block body %}
    <div class="row row-sm justify-content-center mt-5">
        <div class="col-10">
            <div class="card custom-card">
                <div class="card-header  p-3 tx-semibold tx-white bg-primary">
                    Liste des édition
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-bordered text-nowrap border-bottom" id="basic-datatable">
                            <thead>
                            <tr>
                                <th class="text-center">#</th>
                                <th class="text-center">Edition</th>
                                <th class="text-center">Titre</th>
                                <th class="text-center">Action</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for index, p in pages %}
                                <tr>
                                    <th class="text-center">{{ index + 1 }}</th>
                                    <th class="">{{ p.edition }}</th>
                                    <th class="">{{ p.titre }}</th>
                                    <th class="text-center">
                                        <a href="{{ path('app_galerie_detail_galerie_show', {'id' : p.id}) }}">
                                            <i class="fa fa-eye"></i>
                                        </a>
                                    </th>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>

                </div>
                <div class="card-footer">
                    <a href="{{ path('app_galerie_detail_galerie_new') }}" class="btn btn-primary float-end">Nouveau</a>
                </div>
            </div>
        </div> <!-- end col -->
    </div> <!-- end row -->

{% endblock %}

