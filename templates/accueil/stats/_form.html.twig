<fieldset>
    <legend>Information Stat</legend>
    <div class="row">
        <div class="col-md-6">
            <div class="mb-3">
                <label class="form-label">Label</label>
                {{ form_widget(form.label,{attr: {class: 'form-control' ~ ((form_errors(form.label)) ? ' is-invalid' : (form.vars.data.label ? ' is-valid' : '' )) }}) }}
                <div class="invalid-feedback">
                    {{form_errors(form.label)}}
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="mb-3">
                <label class="form-label">Valeur</label>
                {{ form_widget(form.valeur,{attr: {class: 'form-control' ~ ((form_errors(form.valeur)) ? ' is-invalid': (form.vars.data.valeur ? ' is-valid' : '' ))}}) }}
                <div class="invalid-feedback">
                    {{form_errors(form.valeur)}}
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-check mb-3">
                {{ form_widget(form.plus,{attr: {class: 'form-check-input' ~ ((form_errors(form.plus)) ? ' is-invalid': (form.vars.data.plus ? ' is-valid' : '' ))}}) }}
                <label class="form-check-label" for="stats_acceuil_plus">Ajouter le plus?</label>
                <div class="invalid-feedback">
                    {{form_errors(form.plus)}}
                </div>
            </div>
        </div>
    </div>
</fieldset>
