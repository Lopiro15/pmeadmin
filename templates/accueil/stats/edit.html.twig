{% extends 'base.html.twig' %}

{% block stylesheets %}
    {{ parent() }}

{% endblock %}

{% block body %}
    <div class="row row-sm justify-content-center mt-5">
        <div class="col-md-10">
            {{ form_start(form) }}
            <div class="card custom-card">
                <div class="card-header p-3 tx-semibold tx-white bg-primary">
                    Modifier une Stat
                </div>
                <div class="card-body">
                    {% include 'accueil/stats/_form.html.twig' %}
                </div>
                <div class="card-footer">
                    <div class="form-group">
                        <button type="submit" class="btn btn-primary float-end"> <i class="fa fa-save"></i> Enregistrer</button>
                        <a href="{{ path('app_accueil_stats_index') }}" class="btn btn-secondary float-end me-2"> <i class="fa fa-arrow-circle-left"></i> Retour</a>
                    </div>
                </div>
                <!-- end card body -->
            </div>
            {{ form_end(form) }}
            <!-- end card -->
        </div>
    </div>
{% endblock %}


{% block javascripts %}
    {{ parent() }}

{% endblock %}



