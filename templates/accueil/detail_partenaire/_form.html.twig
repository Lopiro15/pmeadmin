<fieldset>
    <legend>Information partenaire</legend>
    <div class="row">

        <div class="col-md-6">
            <div class="mb-3">
                <label class="form-label">Nom entreprise</label>
                {{ form_widget(form.labelEntreprise,{attr: {class: 'form-control' ~ ((form_errors(form.labelEntreprise)) ? ' is-invalid' : (form.vars.data.labelEntreprise ? ' is-valid' : '' )) }}) }}
                <div class="invalid-feedback">
                    {{form_errors(form.labelEntreprise)}}
                </div>
            </div>
        </div>
        <div class="col-md-12">
            <div class="mb-3">
                <label class="form-label">Image</label>
                {{ form_widget(form.file,{attr: {class: ' dropify', 'data-height': '200', 'data-default-file': ((form.vars.value) ?  vich_uploader_asset(form.vars.value, 'file') : '')}}) }}
                {{ form_errors(form.file) }}
            </div>
        </div>
    </div>
</fieldset>
