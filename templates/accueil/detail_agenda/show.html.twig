{% extends 'base.html.twig' %}

{% block body %}
    <div class="row row-sm justify-content-center mt-5">
        <div class="col-xl-10">
            <div class="card custom-card overflow-hidden">
                <div class="card-body">
                    <div class="item-card-desc d-flex mb-2">
                        <a href="javascript:;" class="d-flex me-4">
                            {#                            <i class="fe fe-calendar fs-18 me-2"></i>#}
                            <span class="my-auto text-dark">{{ article.debut | date("H:i") }} - {{ article.fin | date("H:i") }}: {{ article.badge | raw }}</span>
                        </a>
                    </div>
                    <h4>{{ article.titre }} - {{ article.lieu }}</h4>
                    <div>{{ article.description | raw }}</div>

                </div>
                <div class="card-footer">
                    {{ include('accueil/detail_agenda/_delete_form.html.twig') }}
                    <a href="{{ path('app_accueil_detail_agenda_edit', {'id': article.id}) }}" class="btn btn-primary float-end me-2"> <i class="fas fa-edit"></i> Modifier</a>
                    <a href="{{ path('app_accueil_detail_agenda_index') }}" class="btn btn-primary float-end me-2"> <i class="fas fa-arrow-circle-left"></i> Retour</a>
                </div>
            </div>
        </div>
        <!--end col-->
        <!--end col-->
    </div>
{% endblock %}




