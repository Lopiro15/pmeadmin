<fieldset>
    <legend>Information entreprise</legend>
    <div class="row">

        <div class="col-md-6">
            <div class="mb-3">
                <label class="form-label">Raison social</label>
                {{ form_widget(form.raisonSocial,{attr: {class: 'form-control' ~ ((form_errors(form.raisonSocial)) ? ' is-invalid' : (form.vars.data.raisonSocial ? ' is-valid' : '' )) }}) }}
                <div class="invalid-feedback">
                    {{form_errors(form.raisonSocial)}}
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="mb-3">
                <label class="form-label">lien facebook</label>
                {{ form_widget(form.facebook,{attr: {class: 'form-control' ~ ((form_errors(form.facebook)) ? ' is-invalid': (form.vars.data.facebook ? ' is-valid' : '' ))}}) }}
                <div class="invalid-feedback">
                    {{form_errors(form.facebook)}}
                </div>
            </div>
        </div>
        <div class="col-md-12">
            <div class="mb-3">
                <label class="form-label">Lien linkedin</label>
                {{ form_widget(form.linkedin,{attr: {class: 'form-control ' ~ ((form_errors(form.linkedin)) ? ' is-invalid': (form.vars.data.linkedin ? ' is-valid' : '' ))}}) }}
                <div class="invalid-feedback">
                    {{form_errors(form.linkedin)}}
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="mb-3">
                <label class="form-label">Site web</label>
                {{ form_widget(form.siteWeb,{attr: {class: 'form-control' ~ ((form_errors(form.siteWeb)) ? ' is-invalid': (form.vars.data.siteWeb ? ' is-valid' : '' ))}}) }}
                <div class="invalid-feedback">
                    {{form_errors(form.siteWeb)}}
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="mb-3">
                <label class="form-label">Badge</label>
                {{ form_widget(form.badge,{attr: {class: 'form-control' ~ ((form_errors(form.badge)) ? ' is-invalid': (form.vars.data.badge ? ' is-valid' : '' ))}}) }}
                <div class="invalid-feedback">
                    {{form_errors(form.badge)}}
                </div>
            </div>
        </div>
        <div class="col-md-12">
            <div class="mb-3">
                <label class="form-label">Image</label>
                {{ form_widget(form.imageFile,{attr: {class: ' dropify', 'data-height': '200', 'data-default-file': ((form.vars.value) ?  vich_uploader_asset(form.vars.value, 'imageFile') : '')}}) }}
                {{ form_errors(form.imageFile) }}
            </div>
        </div>
    </div>
</fieldset>
