{% form_theme form 'sponsor/package/_collection.html.twig' %}

<fieldset>
    <legend>Information Pack</legend>
    <div class="row align-items-center">
        <div class="col-md-6">
            <div class="mb-3">
                <label class="form-label">Type</label>
                {{ form_widget(form.code,{attr: {class: 'form-control select2' ~ ((form_errors(form.code)) ? ' is-invalid': (form.vars.data.code ? ' is-valid' : '' ))}}) }}
                <div class="invalid-feedback">
                    {{form_errors(form.code)}}
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="mb-3">
                <label class="form-label">Libellé</label>
                {{ form_widget(form.nom,{attr: {class: 'form-control' ~ ((form_errors(form.nom)) ? ' is-invalid' : (form.vars.data.nom ? ' is-valid' : '' )) }}) }}
                <div class="invalid-feedback">
                    {{form_errors(form.nom)}}
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="mb-3">
                <label class="form-label">Tarif</label>
                {{ form_widget(form.tarif,{attr: {class: 'form-control' ~ ((form_errors(form.tarif)) ? ' is-invalid' : (form.vars.data.tarif ? ' is-valid' : '' )) }}) }}
                <div class="invalid-feedback">
                    {{form_errors(form.tarif)}}
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <label class="custom-switch">
                {{ form_widget(form.popu,{attr: {class: 'custom-switch-input'}}) }}
                <span class="custom-switch-indicator"></span>
                <span class="custom-switch-description">Le plus populaire ?</span>
            </label>
        </div>
        <div class="col-md-12">
            <div class="mb-3">
                <label class="form-label">Description</label>
                {{ form_widget(form.description,{attr: {class: 'form-control' ~ ((form_errors(form.description)) ? ' is-invalid': (form.vars.data.description ? ' is-valid' : '' ))}}) }}
                <div class="invalid-feedback">
                    {{form_errors(form.description)}}
                </div>
            </div>
        </div>
    </div>

</fieldset>
{% if form.avantages is defined %}
    <fieldset>
        <legend>Avantages</legend>
        <div class="table-responsive">
            <input type="hidden" id="widget-counter-price-produits" value="{{ form.avantages|length }}">
            <table class="table table-bordered bordered" id="table-collection-price-produits">
                <thead class="bg-soft-dark">
                <tr>
                    <th class="text-center w-75">Description</th>
                    <th class="text-center w-25">Action</th>
                </tr>
                </thead>
                <tbody>
                {{ form_widget(form.avantages) }}
                </tbody>
                <tfoot>
                </tfoot>
            </table>
        </div>
    </fieldset>
{% endif %}