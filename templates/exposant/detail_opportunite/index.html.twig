{% extends 'base.html.twig' %}

{% block stylesheets %}
    {{ parent() }}

{% endblock %}

{% block body %}
    <div class="row row-sm justify-content-center mt-5">
        <div class="col-10">
            <div class="card custom-card">
                <div class="card-header  p-3 tx-semibold tx-white bg-primary">
                    Liste des opportunités
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-bordered border-bottom" id="basic-datatable">
                            <thead>
                            <tr>
                                <th class="text-center">N°</th>
                                <th class="text-center">Icon svg</th>
                                <th class="text-center">Badge</th>
                                <th class="text-center">Titre</th>
                                <th class="text-center">Description</th>
                                <th class="text-center">Lien détail</th>
                                <th class="text-center">Action</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for index, a in articles %}
                                <tr>
                                    <th class="text-center">{{ index + 1 }}</th>
                                    <th>{{ a.svg | raw }}</th>
                                    <th>{{ a.badge }}</th>
                                    <th>{{ a.titre }}</th>
                                    <th>{{ a.description }}</th>
                                    <th>{{ a.linkDetail }}</th>
                                    <th class="text-center">
                                        <a href="{{ path('app_exposant_detail_opportunite_show', {'id' : a.id}) }}">
                                            <i class="fa fa-eye"></i>
                                        </a>
                                    </th>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>

                </div>
                <div class="card-footer">
                    <a href="{{ path('app_exposant_detail_opportunite_new') }}" class="btn btn-primary float-end">Nouveau</a>
                </div>
            </div>
        </div> <!-- end col -->
    </div> <!-- end row -->

{% endblock %}

