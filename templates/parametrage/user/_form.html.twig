{% if editing is not defined %}

<fieldset>
    <legend>Informations Personnelles</legend>
    <div class="row">
        <div class="col-md-6">
            <div class="mb-3">
                <label class="form-label">Nom</label>
                {{ form_widget(form.lastName,{attr: {class: 'form-control' ~ ((form_errors(form.lastName)) ? ' is-invalid' : (form.vars.data.lastName ? ' is-valid' : '' )) }}) }}
                <div class="invalid-feedback">
                    {{form_errors(form.lastName)}}
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="mb-3">
                <label class="form-label">Prénoms</label>
                {{ form_widget(form.firstName,{attr: {class: 'form-control' ~ ((form_errors(form.firstName)) ? ' is-invalid' : (form.vars.data.firstName ? ' is-valid' : '' )) }}) }}
                <div class="invalid-feedback">
                    {{form_errors(form.firstName)}}
                </div>
            </div>
        </div>
    </div>

</fieldset>

{% endif %}

<fieldset>
    <legend>Compte Utilisateur</legend>
    <div class="row">
        <div class="col-md-6">
            <div class="mb-3">
                <label class="form-label">Email</label>
                {{ form_widget(form.email,{attr: {class: 'form-control' ~ ((form_errors(form.email)) ? ' is-invalid' : (form.vars.data.email ? ' is-valid' : '' )) }}) }}
                <div class="invalid-feedback">
                    {{form_errors(form.email)}}
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="mb-3">
                <label class="form-label">Téléphone</label>
                {{ form_widget(form.phone,{attr: {class: 'form-control' ~ ((form_errors(form.phone)) ? ' is-invalid' : (form.vars.data.phone ? ' is-valid' : '' )) }}) }}
                <div class="invalid-feedback">
                    {{form_errors(form.phone)}}
                </div>
            </div>
        </div>
    </div>
    {% if editing is not defined %}
    <div class="row">
        <div class="col-md-6">
            <label class="custom-switch">
                {{ form_widget(form.enable,{attr: {class: 'custom-switch-input'}}) }}
                <span class="custom-switch-indicator"></span>
                <span class="custom-switch-description">Etat de l'utilisateur</span>
            </label>
        </div>
    </div>
    {% endif %}
</fieldset>

<fieldset>
    <legend>Confirmation</legend>
    <div class="row">
        <div class="col-md-6">
            <div class="mb-3">
                <label class="form-label">Mot de passe de confirmation</label>
                {{ form_widget(form.password,{attr: {class: 'form-control ' }}) }}
                {{form_errors(form.password)}}
            </div>
        </div>
    </div>
</fieldset>