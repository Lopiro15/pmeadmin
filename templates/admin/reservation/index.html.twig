{% extends 'base.html.twig' %}

{% block stylesheets %}
    {{ parent() }}

{% endblock %}

{% block body %}
    <div class="row row-sm justify-content-center mt-5">
        <div class="col-10">
            <div class="card custom-card">
                <div class="card-header  p-3 tx-semibold tx-white bg-primary">
                    Liste des reservations
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-bordered text-nowrap border-bottom" id="basic-datatable">
                            <thead>
                            <tr>
                                <th class="text-center">Nom complet</th>
                                <th class="text-center">Téléphone</th>
                                <th class="text-center">Email</th>
                                <th class="text-center">Fonction</th>
                                <th class="text-center">Ticket</th>
                                <th class="text-center">Quantité</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for r in reservations %}
                                <tr>
                                    <th class="">{{ r.fullname }}</th>
                                    <th>{{ r.telephone }}</th>
                                    <th class="">{{ r.email }}</th>
                                    <th>{{ r.fonction }}</th>
                                    <th class="">{{ r.typeTicket.label }}</th>
                                    <th>{{ r.quantity }}</th>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>

                </div>
{#                <div class="card-footer">#}
{#                    <a href="{{ path('app_admin_offre_new') }}" class="btn btn-primary float-end">Nouveau</a>#}
{#                </div>#}
            </div>
        </div> <!-- end col -->
    </div> <!-- end row -->

{% endblock %}

